{
  "name": "node-omni-orcha",
  "version": "0.1.0",
  "description": "Unified native Node.js bindings — single omni.node for LLM, STT, TTS, and Image/Video generation",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "build": "cmake-js compile --CDGPU_BACKEND=auto",
    "build:metal": "cmake-js compile --CDGPU_BACKEND=metal",
    "build:cuda": "cmake-js compile --CDGPU_BACKEND=cuda",
    "build:cpu": "cmake-js compile --CDGPU_BACKEND=cpu",
    "rebuild": "cmake-js rebuild",
    "clean": "cmake-js clean",
    "test": "node --test test/*.test.ts",
    "test:llm": "node --test test/llm.test.ts",
    "test:unit": "node --test test/model-detector.test.ts test/gguf-reader.test.ts",
    "test:samuel": "node scripts/samuel-jackson-test.ts",
    "serve": "MODELS_DIR=$HOME/.orcha/workspace/.models LLM_MODEL=$HOME/.orcha/workspace/.models/Qwen3.5-4B-IQ4_NL.gguf TTS_MODEL=$HOME/.orcha/workspace/.models/qwen3-tts node server.ts"
  },
  "dependencies": {
    "node-addon-api": "^8.3.1"
  },
  "optionalDependencies": {
    "@agent-orcha/node-omni-orcha-darwin-arm64": "0.1.0",
    "@agent-orcha/node-omni-orcha-linux-x64": "0.1.0",
    "@agent-orcha/node-omni-orcha-linux-arm64": "0.1.0",
    "@agent-orcha/node-omni-orcha-win32-x64": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "cmake-js": "^7.3.0",
    "typescript": "^5.8.0"
  },
  "files": [
    "src/"
  ],
  "keywords": [
    "llm", "tts", "stt", "whisper", "llama", "stable-diffusion", "flux",
    "qwen", "qwen3-tts", "voice-cloning", "speech-to-text", "text-to-speech",
    "image-generation", "ggml", "gguf", "native", "n-api", "metal", "cuda"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ddalcu/node-omni-orcha"
  }
}
